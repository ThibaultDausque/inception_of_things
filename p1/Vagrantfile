Vagrant.configure("2") do |config|
   config.vm.box = "debian/jessie64"
   config.vm.box_version = "8.11.0"
   config.vm.synced_folder ".", "/vagrant", disabled: false

   config.vmdefine "master" do |master|
		master.vm.hostname = "aroulleaS"
		master.vm.network "network", ip: "192.168.56.110"
		master.vm.provider "libvirt" do |libvirt|
			libvirt.cpus = 1
			libvirt.memory = "524"
			libvirt.driver = "kvm"
		end
	   master.vm.provision "shell", path: "./script/master.sh"
	end

	config.vmdefine "worker" do |worker|
		worker.vm.hostname = "aroulleaSW"
		master.vm.network "network", ip: "192.168.56.111"
		master.vm.provider "libvirt" do |libvirt|
			libvirt.cpus = 1
			libvirt.memory = "524"
			libvirt.driver = "kvm"
		end
	   master.vm.provision "shell", path: "./script/worker.sh"
	end
end
